        "price",
        "how much",
        "cost"
      ]
    },
    "steps": [
      {
        "type": "send_message",
        "message": "Hey! Saw your comment 😊 Here's our pricing page: https://yourwebsite.com/pricing — feel free to reply here if you have questions!"
      }
    ]
  },
  {

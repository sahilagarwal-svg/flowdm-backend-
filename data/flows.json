[
  {
    "id": "flow_welcome",
    "name": "Welcome DM sequence",
    "active": true,
    "trigger": {
      "type": "new_follower"
    },
    "steps": [
      {
        "type": "delay",
        "ms": 10000
      },
      {
        "type": "send_message",
        "message": "Hey! Thanks for following 👋 We'd love to help you out — what brings you here today?"
      }
    ]
  },
  {
    "id": "flow_link_keyword",
    "name": "Keyword: \"link\"",
    "active": true,
    "trigger": {
      "type": "keyword",
      "keywords": [
